---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  
  {% comment %} 1. المقالات والمستجدات {% endcomment %}
  {% for post in site.posts %}
    <url>
      <loc>{{ post.url | absolute_url }}</loc>
      {% if post.last_modified_at %}
        <lastmod>{{ post.last_modified_at | date_to_xmlschema }}</lastmod>
      {% else %}
        <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
      {% endif %}
      <changefreq>weekly</changefreq>
      <priority>0.8</priority>
    </url>
  {% endfor %}

  {% comment %} 2. الصفحات الأساسية (مع حماية بنية الروابط الفاخرة) {% endcomment %}
  {% for page in site.pages %}
    {% unless page.url contains '404' or page.url contains 'google' or page.url contains 'dacda97e' or page.url contains '.css' or page.url contains '.js' %}
      <url>
        <loc>{{ page.url | absolute_url }}</loc>
        <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>{% if page.url == '/' %}1.0{% else %}0.7{% endif %}</priority>
      </url>
    {% endunless %}
  {% endfor %}

  {% comment %} 3. العقارات الفردية بالروابط الإنجليزية المستقرة {% endcomment %}
  {% for property in site.properties %}
    <url>
      <loc>{{ property.url | absolute_url }}</loc>
      <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
      <changefreq>weekly</changefreq>
      <priority>0.9</priority>
    </url>
  {% endfor %}

  {% comment %} 4. الطلبات الفردية بالروابط الإنجليزية المستقرة {% endcomment %}
  {% for request in site.requests %}
    <url>
      <loc>{{ request.url | absolute_url }}</loc>
      <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
      <changefreq>weekly</changefreq>
      <priority>0.9</priority>
    </url>
  {% endfor %}

</urlset>
