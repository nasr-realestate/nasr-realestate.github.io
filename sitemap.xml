---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for post in site.posts %}
    <url>
      <loc>{{ site.url }}{{ post.url }}</loc>
      {% if post.last_modified_at %}
        <lastmod>{{ post.last_modified_at | date_to_xmlschema }}</lastmod>
      {% else %}
        <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
      {% endif %}
      <changefreq>weekly</changefreq>
      <priority>0.8</priority>
    </url>
  {% endfor %}
  {% for page in site.pages %}
    {% if page.url contains '.html' or page.url == '/' %}
      {% unless page.url contains '404' or page.url contains 'google' or page.url contains 'dacda97e' %}
        <url>
          <loc>{{ site.url }}{{ page.url }}</loc>
          <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
          <changefreq>monthly</changefreq>
          <priority>{% if page.url == '/' %}1.0{% else %}0.7{% endif %}</priority>
        </url>
      {% endunless %}
    {% endif %}
  {% endfor %}
  {% for property in site.properties %}
    <url>
      <loc>{{ site.url }}{{ property.url }}</loc>
      <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
      <changefreq>weekly</changefreq>
      <priority>0.9</priority>
    </url>
  {% endfor %}
  {% for request in site.requests %}
    <url>
      <loc>{{ site.url }}{{ request.url }}</loc>
      <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
      <changefreq>weekly</changefreq>
      <priority>0.9</priority>
    </url>
  {% endfor %}
</urlset>
