---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for page in site.pages %}
    {% unless page.url contains '404.html' or page.url contains '.css' or page.url contains '.json' or page.url contains '.xml' or page.url contains '/assets/' or page.url contains 'feed.xml' %}
    <url>
      <loc>{{ site.url }}{{ page.url }}</loc>
      {% if page.last_modified_at %}
      <lastmod>{{ page.last_modified_at | date: "%Y-%m-%d" }}</lastmod>
      {% elsif page.date %}
      <lastmod>{{ page.date | date: "%Y-%m-%d" }}</lastmod>
      {% endif %}
    </url>
    {% endunless %}
  {% endfor %}
  
  {% for collection in site.collections %}
    {% for doc in collection.docs %}
    <url>
      <loc>{{ site.url }}{{ doc.url }}</loc>
      {% if doc.last_modified_at %}
      <lastmod>{{ doc.last_modified_at | date: "%Y-%m-%d" }}</lastmod>
      {% elsif doc.date %}
      <lastmod>{{ doc.date | date: "%Y-%m-%d" }}</lastmod>
      {% endif %}
    </url>
    {% endfor %}
  {% endfor %}
</urlset>
