---
layout: null
sitemap: false
seo: false
---<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for page in site.pages %}{% if page.url != "/sitemap.xml" and page.url != "/robots.txt" %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    <lastmod>{{ site.time | date: "%Y-%m-%d" }}</lastmod>
  </url>{% endif %}{% endfor %}
  {% for collection in site.collections %}{% for item in collection.docs %}
  <url>
    <loc>{{ site.url }}{{ item.url }}</loc>
    <lastmod>{{ item.date | date: "%Y-%m-%d" }}</lastmod>
  </url>{% endfor %}{% endfor %}
</urlset>
