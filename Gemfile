source "https://rubygems.org"

# نسخة GitHub Pages التي تحتوي على معظم الإضافات المدعومة
gem "github-pages", "~> 231", group: :jekyll_plugins

# الإضافات التي تحتاجها لموقعك
group :jekyll_plugins do
  gem "jekyll-sitemap"
  gem "jekyll-seo-tag"
  gem "jekyll-feed"
end

# ضروري لعمل Jekyll على النسخ الحديثة من Ruby
gem "webrick"
